# ─────────────────────────────────────────────────────────
# TMDB — Elige UNO de los dos métodos de autenticación
# ─────────────────────────────────────────────────────────

# Método 1 ✅ RECOMENDADO: API Read Access Token (JWT)
# Obténlo en: https://www.themoviedb.org/settings/api
# → "API Read Access Token" (sección "API Key v4 auth")
TMDB_READ_ACCESS_TOKEN=eyJhbGciOiJIUzI1NiJ9...

# Método 2: API Key clásica v3 + Session ID
# Sólo necesario si NO usas TMDB_READ_ACCESS_TOKEN
# TMDB_API_KEY=tu_api_key_aqui
# TMDB_SESSION_ID=tu_session_id

# ID numérico de tu cuenta TMDB
# → https://www.themoviedb.org/settings/account → "Member since..." o via API /account
# Si usas TMDB_READ_ACCESS_TOKEN, puedes omitir esto (se detecta automáticamente)
TMDB_ACCOUNT_ID=12345678

# ─────────────────────────────────────────────────────────
# Jellyfin
# ─────────────────────────────────────────────────────────
JELLYFIN_URL=http://192.168.1.100:8096
JELLYFIN_API_KEY=tu_jellyfin_api_key
# Opcional: si no se define, se usa el primer usuario disponible
# JELLYFIN_USER_ID=tu_user_id_jellyfin

# ─────────────────────────────────────────────────────────
# Servidor
# ─────────────────────────────────────────────────────────
PORT=4895
